{% extends "layout-v2.njk" %}

{% block content %}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>{{ title }}</h1>
        <p class="text-muted mb-0">Read-only transaction ledger.</p>
    </div>
    <a href="/clients" class="btn btn-outline-secondary shadow-sm">&larr; Back to Clients</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3">Date</th>
                        <th class="py-3">Transaction Type</th>
                        <th class="py-3">Reference</th>
                        <th class="px-4 py-3 text-end">Amount (Credits)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tx in transactions %}
                    <tr>
                        <td class="px-4 text-muted align-middle">{{ tx.createdAt }}</td>
                        <td class="align-middle">
                            {% if tx.type == 'recharge' %}
                                <span class="badge bg-success">Top Up</span>
                            {% elif tx.type == 'deduction' %}
                                <span class="badge bg-secondary">Campaign Send</span>
                            {% elif tx.type == 'refund' %}
                                <span class="badge bg-info text-dark">Refund</span>
                            {% else %}
                                <span class="badge bg-light text-dark">{{ tx.type }}</span>
                            {% endif %}
                        </td>
                        <td class="align-middle">{{ tx.reference }}</td>
                        <td class="px-4 text-end fw-bold align-middle {% if tx.amount > 0 %}text-success{% else %}text-danger{% endif %}">
                            {{ tx.amount }}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            No transactions found for this client.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}