{% extends "layout-v2.njk" %} 

{% block content %}
<div class="page-header">
    <h1>{{ title }}</h1>
    <p>Upload a CSV to launch a bulk campaign.</p>
</div>

<div class="campaign-card">
    <div class="form-group">
        <label>Campaign Name</label>
        <input type="text" id="campaignName" placeholder="e.g., Q4 Promo" class="form-control">
    </div>

    <div class="form-group">
        <label>Sender ID</label>
        <select id="senderId" class="form-control">
            <option value="InfoSMS">InfoSMS</option>
            <option value="PromoAlert">PromoAlert</option>
        </select>
    </div>

    <div class="form-group file-upload-zone">
        <label for="csvFileInput">Upload Contacts (CSV)</label>
        <input type="file" id="csvFileInput" accept=".csv" class="form-control">
        <small>File must contain a column named "Phone" or "MSISDN". Max size: 100MB.</small>
    </div>

    <div id="uploadStatus" class="status-alert" style="font-weight: bold; margin: 15px 0;"></div>

    <button id="startUploadBtn" class="btn btn-primary">Process & Send Campaign</button>
</div>

<div id="liveProgressCard" style="display: none; margin-top: 20px;">
    <h3>Campaign Live Progress</h3>
    <p>Sent: <span id="wsSentCount">0</span></p>
    <p>Failed: <span id="wsFailedCount">0</span></p>
</div>

{% endblock %}

{% block scripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

<script src="/socket.io/socket.io.js"></script>

<script src="/js/customjs/bulk-upload.js"></script>
{% endblock %}