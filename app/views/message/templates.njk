{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ title }}</h2>
        <button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#newTemplateModal">
            + Request New Template
        </button>
    </div>

    <div class="row">
        {% for tpl in templates %}
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom-0">
                    <h6 class="mb-0 fw-bold">{{ tpl.name }}</h6>
                    {% if tpl.status == 'Approved' %}
                        <span class="badge bg-success bg-opacity-10 text-success">Approved</span>
                    {% elif tpl.status == 'Pending' %}
                        <span class="badge bg-warning bg-opacity-10 text-warning">Pending Review</span>
                    {% else %}
                        <span class="badge bg-danger bg-opacity-10 text-danger">Rejected</span>
                    {% endif %}
                </div>
                <div class="card-body bg-light rounded-bottom m-2 mt-0 p-3">
                    <p class="font-monospace text-muted mb-0" style="font-size: 0.9em;">
                        {{ tpl.content }}
                    </p>
                </div>
                <div class="card-footer bg-white border-0 text-end">
                    <button class="btn btn-sm btn-outline-secondary">Edit</button>
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12 text-center py-5 text-muted">
            <span style="font-size: 3rem;">📝</span>
            <h5 class="mt-3">No templates yet</h5>
            <p>Create a template to speed up your bulk campaigns and ensure compliance.</p>
        </div>
        {% endfor %}
    </div>
</div>

<div class="modal fade" id="newTemplateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">Request Template Approval</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form action="/messages/templates" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Template Name</label>
                        <input type="text" class="form-control" placeholder="e.g., Order Confirmation" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message Content</label>
                        <textarea class="form-control font-monospace" rows="4" placeholder="Use [Variables] for dynamic data..." required></textarea>
                        <small class="text-muted">Max 160 characters per SMS.</small>
                    </div>
                    <button type="button" class="btn btn-primary w-100" data-bs-dismiss="modal">Submit for Review (WIP)</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}