{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ title }}</h2>
        
        {% if targetClientId %}
            <a href="/clients" class="btn btn-secondary">&larr; Back to Clients</a>
        {% else %}
            <button class="btn btn-primary">+ Invite User</button>
        {% endif %}
    </div>

    <div class="card p-4">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for teamMember in users %}
                <tr>
                    <td>{{ teamMember.full_name }}</td>
                    <td>{{ teamMember.email }}</td>
                    <td><span class="badge bg-dark">{{ teamMember.role }}</span></td>
                    <td><span class="text-success">Active</span></td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">No users found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>


<div class="modal fade" id="wipInviteModal" tabindex="-1" aria-labelledby="wipInviteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pb-5">
                <div class="mb-3">
                    <span style="font-size: 3rem;">🚧</span>
                </div>
                <h4 class="modal-title mb-2" id="wipInviteModalLabel">Work In Progress</h4>
                <p class="text-muted">The user invitation flow is currently being constructed. Check back soon!</p>
                <button type="button" class="btn btn-secondary mt-3" data-bs-dismiss="modal">Understood</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}