{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <h1>Welcome back!</h1>
    
    <div class="row">
        <div class="col-md-4">
            <div class="card p-3">
                <h3>Balance</h3>
                <h2 class="text-primary">{{ stats.balance }}</h2> 
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3">
                <h3>Sent Today</h3>
                <h2 class="text-success">{{ stats.totalSent }}</h2>
            </div>
        </div>
    </div>

    <div class="card p-4 mt-3">
        <h3>Recent Campaigns</h3>
        <table class="table table-hover">
            <thead>
                <tr><th>Name</th><th>Status</th><th>Sent</th></tr>
            </thead>
            <tbody>
                {% for campaign in recentActivity %}
                <tr>
                    <td>{{ campaign.name }}</td>
                    <td><span class="badge bg-info">{{ campaign.status }}</span></td>
                    <td>{{ campaign.totalSent }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/customjs/dashboard.js"></script>
{% endblock %}