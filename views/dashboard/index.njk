{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <a href="/accounts/billing" class="btn btn-outline-secondary">Top Up Wallet</a>
            <a href="/messages" class="btn btn-primary">Launch Campaign</a>
        </div>
    </div>
    
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-left-primary h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Available Balance</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800">{{ stats.currency }} {{ stats.balance }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-left-success h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Sent</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800" id="dash-total-sent">{{ stats.totalSent | default('0') }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-left-danger h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Failed Delivery</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800" id="dash-total-failed">{{ stats.failed | default('0') }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-left-info h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Active Sender IDs</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800">--</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-white border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-dark">Recent Campaigns</h6>
                    <a href="/messages#outbox" class="text-sm">View All &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-items-center table-flush mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Campaign Name</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Sent</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for campaign in recentActivity %}
                            <tr>
                                <td><strong>{{ campaign.name }}</strong></td>
                                <td><span class="text-muted small">{{ campaign.date | truncate(10, true, '') }}</span></td>
                                <td>
                                    {% if campaign.status == 'COMPLETED' or campaign.status == 'DELIVERED' %}
                                        <span class="badge badge-success px-2 py-1">{{ campaign.status }}</span>
                                    {% elif campaign.status == 'PROCESSING' %}
                                        <span class="badge badge-primary px-2 py-1">{{ campaign.status }}</span>
                                    {% elif campaign.status == 'SCHEDULED' %}
                                        <span class="badge badge-info px-2 py-1">{{ campaign.status }}</span>
                                    {% else %}
                                        <span class="badge badge-secondary px-2 py-1">{{ campaign.status }}</span>
                                    {% endif %}
                                </td>
                                <td>{{ campaign.totalSent | default('0') }}</td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    No recent campaigns found. <br>
                                    <a href="/messages" class="btn btn-sm btn-outline-primary mt-2">Start your first campaign</a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header py-3 bg-white border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-dark">System Status</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-sm font-weight-bold">Engine Throughput</span>
                            <span class="text-sm text-success">Optimal</span>
                        </div>
                        <div class="progress" style="height: 5px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                        </div>
                    </div>
                    <hr>
                    <p class="text-sm text-muted">
                        <strong>Tip:</strong> You can upload up to 2,000 contacts instantly. For larger files, our background engine will process them securely via Cloud Storage.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/customjs/dashboard.js"></script>
{% endblock %}