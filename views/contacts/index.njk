{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ title }}</h2>
        <div>
            <button class="btn btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#newGroupModal">
                + Create Group
            </button>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#importContactsModal">
                Import CSV
            </button>
        </div>
    </div>

    <div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="mb-0">Contact Groups</h5>
            </div>
            <div class="list-group list-group-flush" id="group-list">
                {% for group in groups %}
                <a href="#" data-group-id="{{ group.id }}" data-group-name="{{ group.name }}" data-group-desc="{{ group.description }}" class="group-link list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    {{ group.name }}
                    <span class="badge bg-secondary rounded-pill group-count">{{ group.contactCount }}</span>
                </a>
                {% else %}
                <div class="p-4 text-center text-muted">
                    <p>No groups created yet.</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0 p-4 h-100" id="contacts-display-pane">
            <div class="text-center text-muted mt-5">
                <span style="font-size: 3rem;">👥</span>
                <h4 class="mt-3">Select a group</h4>
                <p>Click a group on the left to view and manage its contacts, or import a new list.</p>
            </div>
        </div>
    </div>
    </div>
</div>

<div class="modal fade" id="newGroupModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">Create Contact Group</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="new-group-form" action="/api/contacts/groups" method="POST" autocomplete="off">
                    <div class="mb-3">
                        <label class="form-label">Group Name</label>
                        <input type="text" class="form-control" id="groupName" name="groupName" placeholder="e.g., VIP Customers" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Group Description</label>
                        <input type="text" class="form-control" id="groupDescription" name="groupDescription" placeholder="e.g., >= 100,000 USD">
                    </div>
                    
                    <div id="groupStatus" class="alert alert-danger text-center" style="display: none;"></div>

                    <button type="submit" id="saveGroupBtn" class="btn btn-primary w-100">Save Group</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="importContactsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">Import Contacts (CSV)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="form-import-csv" autocomplete="off">
                    <div class="mb-3">
                        <label class="form-label">Destination Group</label>
                        <select class="form-select" id="importGroupId" required>
                            <option value="" disabled selected>Select a group...</option>
                            {% for group in groups %}
                            <option value="{{ group.id }}">{{ group.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">CSV File</label>
                        <input type="file" class="form-control" id="importCsvFile" accept=".csv" required>
                        <div class="form-text">Upload a CSV containing your contact phone numbers. Max 2000 rows for instant import; larger files will be processed in the background.</div>
                    </div>
                    
                    <div class="progress mb-3 d-none" id="importProgressContainer" style="height: 10px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" id="importProgressBar"></div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" id="btn-submit-import">Upload & Import</button>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}
{% block scripts %}
<script src="/js/customjs/contacts.js"></script>
{% endblock %}