{% extends "layout-v2.njk" %}

{% block content %}
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>{{ title }}</h1>
        <p class="text-muted">Manage your address books and contact groups.</p>
    </div>
    <button class="btn btn-primary shadow-sm" data-toggle="modal" data-target="#createGroupModal">
        + New Group
    </button>
</div>

<div class="row mt-4">
    {% for group in groups %}
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center">
                <h4 class="card-title text-truncate" title="{{ group.name }}">{{ group.name }}</h4>
                <p class="text-muted small mb-3">{{ group.description | default('No description provided.') }}</p>
                <h2 class="display-4 text-primary font-weight-bold">{{ group.count | default(0) }}</h2>
                <span class="text-uppercase tracking-wide text-muted small">Total Contacts</span>
            </div>
            <div class="card-footer bg-light border-0 p-3">
                <a href="/contacts/{{ group.id }}" class="btn btn-outline-primary btn-block">Manage Contacts</a>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12 text-center py-5">
        <div class="text-muted mb-3">
            <svg width="64" height="64" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        <h4>No Groups Found</h4>
        <p class="text-muted">You haven't created any contact groups yet.</p>
        <button class="btn btn-primary mt-2" data-toggle="modal" data-target="#createGroupModal">Create Your First Group</button>
    </div>
    {% endfor %}
</div>

<div class="modal fade" id="createGroupModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <form id="createGroupForm">
                <div class="modal-header bg-light border-0">
                    <h5 class="modal-title font-weight-bold">Create New Group</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body p-4">
                    <div class="form-group mb-3">
                        <label for="groupName" class="font-weight-bold">Group Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="groupName" required placeholder="e.g., VIP Customers 2026">
                    </div>
                    <div class="form-group mb-2">
                        <label for="groupDescription" class="font-weight-bold">Description (Optional)</label>
                        <textarea class="form-control" id="groupDescription" rows="3" placeholder="Briefly describe who is in this group..."></textarea>
                    </div>
                    <div id="groupStatus" class="alert alert-danger mt-3" style="display: none; font-size: 0.9em;"></div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4" id="saveGroupBtn">Save Group</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/customjs/contacts.js"></script>
{% endblock %}