{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ title }}</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRoleModal">
            + Create Role
        </button>
    </div>

    <div class="card p-0 border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Role Name</th>
                    <th>Description</th>
                    <th>Permissions</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for role in roles %}
                <tr>
                    <td class="ps-4 fw-bold">{{ role.name }}</td>
                    <td class="text-muted">{{ role.description or 'No description provided' }}</td>
                    <td>
                        {% if role.permissions_count > 0 %}
                            <button class="btn btn-sm btn-light border fw-semibold text-secondary" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#viewPermissionsModal"
                                    data-role-id="{{ role.id }}"
                                    data-role-name="{{ role.name }}">
                                <i class="bi bi-eye me-1"></i> View {{ role.permissions_count }} Permissions
                            </button>
                        {% else %}
                            <span class="text-muted small"><em>No permissions</em></span>
                        {% endif %}
                    </td>
                    <td class="text-end pe-4">
                        <button class="btn btn-sm btn-outline-primary me-1" title="Edit Role">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" title="Delete Role">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-2 d-block mb-2 text-secondary"></i>
                        No custom roles found. Create one to get started!
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    </div>
    </div>

<div class="modal fade" id="createRoleModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Create New Role</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="createRoleForm">
        <div class="modal-body">
          <input type="hidden" id="client_id" value="{{ user.client_id }}">

          <div class="row mb-3">
              <div class="col-md-6">
                  <label class="form-label">Role Name</label>
                  <input type="text" class="form-control" id="role_name" required>
              </div>
              <div class="col-md-6">
                  <label class="form-label">Description</label>
                  <input type="text" class="form-control" id="role_description">
              </div>
          </div>

          <hr>
          
          <h6 class="mb-3">Assign Permissions</h6>
          <div id="permissionsLoading" class="text-muted">Loading available permissions...</div>
          
          <div id="permissionsContainer" class="row"></div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary" id="saveRoleBtn">Create Role</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="viewPermissionsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-light">
        <h5 class="modal-title">
            Permissions: <span id="viewPermsRoleName" class="fw-bold text-primary"></span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        
        <div id="viewPermsLoading" class="text-center py-5">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
          <p class="text-muted mt-2 mb-0">Fetching permissions...</p>
        </div>
        
        <div id="viewPermsContainer" class="d-none"></div>

      </div>
      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    const myPermissions = {{ user.permissions | dump | safe }};
</script>
<script src="/js/customjs/roles.js"></script>
{% endblock %}