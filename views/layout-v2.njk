<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}SMS Platform</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    
    <link rel="stylesheet" href="/css/layout.css">
</head>
<body>

    {% if user %}
    <div class="wrapper">
        
        <nav id="sidebar">
            <div class="sidebar-header">
                <h5 class="mb-1 fw-bold text-white"><i class="bi bi-chat-square-dots me-2 text-primary"></i>SMS Platform</h5>
                <small class="text-muted d-block" style="font-size: 0.8em;">Workspace: Client #{{ user.client_id }}</small>
            </div>

            <ul class="list-unstyled components">
                <li class="nav-category">Main</li>
                <li class="{% if alias == 'dashboard' %}active{% endif %}">
                    <a href="/dashboard"><i class="bi bi-grid"></i> Overview</a>
                </li>
                
                <li class="nav-category">Messaging</li>
                <li class="{% if alias == 'message' %}active{% endif %}">
                    <a href="/messages/bulk"><i class="bi bi-send"></i> Bulk SMS</a>
                </li>
                <li class="{% if alias == 'contacts' %}active{% endif %}">
                    <a href="/contacts"><i class="bi bi-person-lines-fill"></i> Address Book</a>
                </li>

                {% if user.role == 'ADMIN' %}
                <li class="nav-category text-warning"><i class="bi bi-shield-lock me-1"></i> Admin Overwatch</li>
                <li class="{% if alias == 'clients' %}active{% endif %}">
                    <a href="/clients"><i class="bi bi-buildings"></i> Client Management</a>
                </li>
                {% endif %}

                <li class="nav-category">Account</li>
                <li class="{% if alias == 'billing' %}active{% endif %}">
                    <a href="/accounts/billing"><i class="bi bi-wallet2"></i> My Wallet & Billing</a>
                </li>
                <li class="{% if alias == 'my-team' %}active{% endif %}">
                    <a href="/clients/my-team"><i class="bi bi-people"></i> My Team</a>
                </li>
                <li class="{% if alias == 'roles' %}active{% endif %}">
                    <a href="/roles"><i class="bi bi-person-badge"></i> Roles & Permissions</a>
                </li>
                <li class="{% if alias == 'settings' %}active{% endif %}">
                    <a href="/settings"><i class="bi bi-gear"></i> Settings & API</a>
                </li>
            </ul>
        </nav>

        <div id="content">
            
            <div class="top-nav">
                <div class="d-flex align-items-center">
                    <button type="button" id="sidebarCollapse" class="btn btn-light shadow-sm me-3">
                        <i class="bi bi-list fs-5"></i>
                    </button>
                    <span class="text-secondary">Welcome back, <strong class="text-dark">{{ user.username }}</strong></span>
                </div>
                <div>
                    <a href="/logout" class="btn btn-sm btn-outline-danger"><i class="bi bi-box-arrow-right me-1"></i> Sign Out</a>
                </div>
            </div>
    {% else %}
    <div class="container mt-5">
        <div class="alert alert-danger shadow-sm border-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>DEBUG: The 'user' object is missing from the template!</div>
    </div>
    {% endif %}

            {% block content %}{% endblock %}

    {% if user %}
        </div> 
    </div> 
    {% endif %}

    <script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function saveObject(key, obj) { localStorage.setItem(key, JSON.stringify(obj)); }
        function getObject(key) { 
            const data = localStorage.getItem(key); 
            return data ? JSON.parse(data) : null; 
        }

        // Mobile Sidebar Toggle Logic
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarBtn = document.getElementById('sidebarCollapse');
            const sidebar = document.getElementById('sidebar');
            
            if (sidebarBtn && sidebar) {
                sidebarBtn.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                });
            }
        });
    </script>

    {% block scripts %}{% endblock %}

</body>
</html>