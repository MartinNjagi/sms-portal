{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ title }}</h2>
        <button class="btn btn-success px-4" data-bs-toggle="modal" data-bs-target="#topUpModal">
            + Top Up Wallet
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100 shadow-sm border-0">
                <div class="card-body p-4">
                    <h6 class="card-title text-uppercase text-white-50">Available Balance</h6>
                    <h2 class="display-5 mb-0">{{ balance | intcomma }} Units</h2>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-4 d-flex align-items-center">
                    <div>
                        <h5 class="text-muted">Billing Plan: <span class="text-dark">Pay-As-You-Go</span></h5>
                        <p class="mb-0 text-muted">Your account will stop sending messages if the balance reaches 0.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 p-4">
        <h4 class="mb-3">Transaction History</h4>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Transaction ID</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th class="text-end">Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tx in wallet.transactions %}
                    <tr>
                        <td>{{ tx.created_at| formatDate}}</td>
                        <td class="text-muted font-monospace">{{ tx.id }}</td>
                        <td>{{ tx.description }}</td>
                        <td>
                            {% if tx.type == 'Credit' %}
                                <span class="badge bg-success bg-opacity-10 text-success">Credit</span>
                            {% else %}
                                <span class="badge bg-danger bg-opacity-10 text-danger">Debit</span>
                            {% endif %}
                        </td>
                        <td class="text-end fw-bold {% if tx.amount > 0 %}text-success{% endif %}">
                            {{ tx.amount | intcomma }}
                        </td>
                        <td>
                            {% if tx.status == 'Completed' %}
                                <span class="text-success"><small>&#9679;</small> Completed</span>
                            {% else %}
                                <span class="text-warning"><small>&#9679;</small> {{ tx.status }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No recent transactions found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="topUpModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom-0 bg-light">
                <h5 class="modal-title">Top Up Wallet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <ul class="nav nav-pills nav-fill mb-4" id="paymentTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#mpesa-tab" type="button">
                            <i class="bi bi-phone"></i> M-Pesa
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#bank-tab" type="button">
                            <i class="bi bi-bank"></i> Bank Receipt
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="mpesa-tab">
                        <form id="form-mpesa-topup">
                            <div class="mb-3">
                                <label class="form-label">Amount (KES)</label>
                                <input type="number" class="form-control" id="mpesaAmount" min="100" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">M-Pesa Phone Number</label>
                                <input type="text" class="form-control" id="mpesaPhone" placeholder="2547XXXXXXXX" required>
                            </div>
                            <button type="submit" class="btn btn-success w-100" id="btn-mpesa-pay">Trigger STK Push</button>
                        </form>

                        <hr class="my-4">
                        <div class="alert alert-secondary border-0 shadow-sm mb-0" role="alert">
                            <h6 class="alert-heading fw-bold text-dark">
                                <i class="bi bi-info-circle text-primary me-1"></i> Manual M-Pesa Top Up
                            </h6>
                            <p class="mb-3 small text-muted">If the STK push prompt does not appear on your phone, you can deposit funds manually using the details below. Your wallet will be credited automatically.</p>
                            
                            <div class="bg-white p-3 rounded border">
                                <ul class="list-unstyled mb-0 small">
                                    <li class="mb-2">1. Go to M-Pesa > Lipa na M-Pesa > <strong>Paybill</strong></li>
                                    <li class="mb-2">2. Business Number: <strong class="text-dark fs-6">{{ paybillNumber }}</strong></li>
                                    <li class="mb-2">3. Account Number: <strong class="text-primary fs-6 font-monospace">{{ wallet.payment_ref }}</strong></li>
                                    <li>4. Enter Amount & M-Pesa PIN</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="bank-tab">
                        <form id="form-bank-topup">
                            <div class="mb-3">
                                <label class="form-label">Amount Deposited (KES)</label>
                                <input type="number" class="form-control" id="bankAmount" min="100" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Bank Reference / Receipt Number</label>
                                <input type="text" class="form-control" id="bankReference" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100" id="btn-bank-pay">Submit Receipt for Approval</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{% block scripts %}
<script src="/js/customjs/billing.js"></script>
{% endblock %}