{% extends "../layout.njk" %}

{% block content %}
<div class="container py-5 text-center">
    <i class="bi {{ icon }} display-1"></i>

    <h1 class="mt-3">{{ code }}</h1>

    <h2>{{ title }}</h2>

    <p class="text-muted">
        {{ message }}
    </p>

    <a href="{{ actionUrl | default('/') }}" class="btn btn-primary">
        {{ actionText | default('Return Home') }}
    </a>
</div>
{% endblock %}