{% extends "layout-v2.njk" %}

{% block content %}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h1>Messaging Dashboard</h1>
    <div>
        <a href="/messages/single" class="btn btn-outline-secondary">Send Single SMS</a>
    </div>
    <div>
        <a href="/messages/templates" class="btn btn-outline-secondary">Templates and Sender IDs</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center py-3">
            <h6 class="text-muted text-uppercase mb-1">Available Balance</h6>
            <h3 class="text-success mb-0">KES <span id="stat-balance">--</span></h3>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-4" id="campaignTabs" role="tablist">
    <li class="nav-item">
        <a class="nav-link active" id="compose-tab" data-toggle="tab" href="#compose" role="tab">Launch Campaign</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="campaigns-tab" data-toggle="tab" href="#campaigns-view" role="tab">Campaigns</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="outbox-tab" data-toggle="tab" href="#outbox" role="tab">Unified Outbox</a>
    </li>
</ul>

<div class="tab-content" id="campaignTabsContent">
    
    <div class="tab-pane fade show active" id="compose" role="tabpanel">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form id="form-launch-campaign" autocomplete="off">
                    <div class="row">
                        <div class="col-md-5 border-right pr-4">
                            <h5 class="mb-4">Campaign Details</h5>
                            
                            <div class="form-group mb-3">
                                <label>Campaign Name</label>
                                <input type="text" id="campName" class="form-control" placeholder="e.g., Easter Promo 2026" required>
                            </div>

                            <div class="form-group mb-3">
                                <label>Sender ID</label>
                                <select id="campSenderId" class="form-control" required>
                                    <option value="" disabled selected>Loading...</option>
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label>Target Audience</label>
                                <select id="campTargetType" class="form-control" required>
                                    <option value="group">Saved Contact Group</option>
                                    <option value="csv">Upload Custom CSV</option>
                                </select>
                            </div>

                            <div id="targetGroupWrapper" class="form-group mb-3">
                                <label>Select Group</label>
                                <select id="campGroupId" class="form-control">
                                    <option value="" disabled selected>Loading groups...</option>
                                </select>
                            </div>

                            <div id="targetCsvWrapper" class="form-group mb-3 d-none">
                                <label>CSV File (Phone Numbers)</label>
                                <input type="file" id="campCsvFile" class="form-control" accept=".csv">
                            </div>

                            <div class="form-group mb-3 bg-light p-3 rounded">
                                <label class="font-weight-bold text-dark mb-1">Schedule For <small class="text-muted">(Optional)</small></label>
                                <input type="datetime-local" id="campScheduledFor" class="form-control">
                                <small class="text-muted d-block mt-1">Leave blank to send immediately.</small>
                            </div>
                        </div>

                        <div class="col-md-7 pl-4">
                            <h5 class="mb-4">Message Configuration</h5>

                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Select Template <span class="text-danger">*</span></label>
                                <select id="campTemplateName" class="form-control" required>
                                    <option value="" disabled selected>Loading templates...</option>
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Template Preview</label>
                                <textarea id="campMessage" class="form-control bg-light" rows="6" placeholder="Select a template above to see the preview..." readonly></textarea>
                                <div class="d-flex justify-content-between mt-2 text-muted small">
                                    <span id="charCount">0 Characters</span>
                                    <span id="smsCount">0 SMS Pages</span>
                                </div>
                            </div>

                            <button type="submit" id="btn-submit-campaign" class="btn btn-primary btn-lg w-100 mt-4">
                                Send / Schedule Campaign
                            </button>
                            
                            <div class="progress mt-3 d-none" id="uploadProgress" style="height: 10px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated w-100"></div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="campaigns-view" role="tabpanel">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-dark">Recent Campaigns</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Campaign Name</th>
                                <th>Status</th>
                                <th>Sent</th>
                                <th>Failed</th>
                                <th>Date/Scheduled Time</th>
                                <th class="text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody id="campaignsTableBody">
                            <tr><td colspan="6" class="text-center py-4">Loading campaigns...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="outbox" role="tabpanel">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-dark">Unified Message Ledger</h6>
                <button id="btn-refresh-outbox" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Recipient</th>
                                <th>Sender ID</th>
                                <th style="max-width: 250px;">Message Preview</th>
                                <th>Cost</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="unifiedOutboxTableBody">
                            <tr><td colspan="7" class="text-center py-4">Loading ledger...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="modal fade" id="campaignStatsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 bg-light">
                <h5 class="modal-title">
                    Campaign: <span id="modalCampName" class="font-weight-bold text-primary">Loading...</span>
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-4">
                <div class="row text-center">
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm border-0 border-left-secondary py-2">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Total Contacts</div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800" id="modalStatTotal">--</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm border-0 border-left-info py-2">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Pending / Processing</div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800" id="modalStatPending">--</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm border-0 border-left-success py-2">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Successfully Sent</div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800" id="modalStatSent">--</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card shadow-sm border-0 border-left-danger py-2">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Failed</div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800" id="modalStatFailed">--</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-center">
                    <button class="btn btn-outline-secondary" id="btn-refresh-stats">Refresh Live Stats</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editCampaignModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form id="form-edit-campaign" autocomplete="off">
                <div class="modal-header border-bottom-0 bg-light">
                    <h5 class="modal-title text-dark font-weight-bold">Edit Scheduled Campaign</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="editCampId">
                    
                    <div class="form-group mb-3">
                        <label>Campaign Name</label>
                        <input type="text" id="editCampName" class="form-control" required>
                    </div>

                    <div class="form-group mb-3">
                        <label>Reschedule Time</label>
                        <input type="datetime-local" id="editCampScheduledFor" class="form-control" required>
                    </div>
                    
                    <div class="alert alert-info small mt-3 mb-0">
                        <i class="fas fa-info-circle"></i> To change the recipient list or message content, please delete this campaign and create a new one.
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" id="btn-save-edit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/customjs/bulk-upload.js"></script>
{% endblock %}