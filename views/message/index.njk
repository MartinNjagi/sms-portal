{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Dashboard Overview</h2>
            <p class="text-muted">Welcome back, {{ user.name | default('User') }}.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/messages" class="btn btn-outline-primary">Bulk Campaign Tool</a>
        </div>
    </div>
    
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-left-primary h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Available Balance</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800 live-wallet-balance">{{ stats.currency }} {{ stats.balance | default('0.00') }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-wallet fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>

    <div class="row">
        
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-dark">Quick Send (Single SMS)</h6>
                </div>
                <div class="card-body">
                    <form id="form-quick-send">
                        
                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label class="form-label">Sender ID</label>
                                <select id="singleSenderId" class="form-control" required>
                                    <option value="" disabled selected>Loading...</option>
                                </select>
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label class="form-label">Recipient Number</label>
                                <input type="text" id="singlePhone" class="form-control" placeholder="e.g., 254700000000" required>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label d-flex justify-content-between">
                                <span>Message Template</span>
                                <small class="text-muted">Optional for Single SMS</small>
                            </label>
                            <select id="singleTemplate" class="form-control">
                                <option value="" selected>-- Custom Message --</option>
                                </select>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label">Message Content</label>
                            <textarea id="singleMessage" class="form-control" rows="4" placeholder="Type your message or select a template above to autofill..." required></textarea>
                            <div class="d-flex justify-content-between mt-1">
                                <small class="text-muted"><span id="singleCharCount">0</span> characters</small>
                            </div>
                        </div>

                        <button type="submit" id="btn-send-single" class="btn btn-primary w-100 py-2">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-dark">Recent Bulk Campaigns</h6>
                    <a href="/messages#outbox" class="small">View All</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Name</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for campaign in recentActivity %}
                            <tr>
                                <td><strong>{{ campaign.name }}</strong></td>
                                <td>
                                    {% if campaign.status == 'COMPLETED' or campaign.status == 'DELIVERED' %}
                                        <span class="badge badge-success px-2 py-1">{{ campaign.status }}</span>
                                    {% elif campaign.status == 'PROCESSING' %}
                                        <span class="badge badge-primary px-2 py-1">{{ campaign.status }}</span>
                                    {% else %}
                                        <span class="badge badge-secondary px-2 py-1">{{ campaign.status }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="2" class="text-center py-4 text-muted">No recent campaigns.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/customjs/messages.js"></script>
{% endblock %}