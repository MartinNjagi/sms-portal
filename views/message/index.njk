{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Dashboard Overview</h2>
            <p class="text-muted">Welcome back, {{ user.name | default('User') }}.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/messages" class="btn btn-outline-primary">Bulk Campaign Tool</a>
        </div>
    </div>
    
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-left-primary h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Available Balance</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800 live-wallet-balance">{{ stats.currency }} {{ stats.balance | default('0.00') }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-wallet fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-dark">Quick Send (Message Constructor)</h6>
                </div>
                <div class="card-body">
                    <form id="form-quick-send">
                        
                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label class="form-label">Sender ID</label>
                                <select id="singleSenderId" class="form-control" required>
                                    <option value="" disabled selected>Loading...</option>
                                </select>
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label class="form-label">Recipient Number</label>
                                <input type="text" id="singlePhone" class="form-control" placeholder="e.g., 254700000000" required>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label d-flex justify-content-between">
                                <span>Message Template</span>
                            </label>
                            <select id="singleTemplate" class="form-control">
                                <option value="" selected>-- Custom Message --</option>
                                </select>
                        </div>

                        <div id="dynamicInputsContainer" class="mb-3 d-none p-3 bg-light rounded border">
                            <h6 class="text-muted mb-3"><i class="fas fa-sliders-h"></i> Template Variables</h6>
                            <div id="dynamicInputsList" class="row"></div>
                        </div>

                        <div class="form-group mb-4" id="manualMessageGroup">
                            <label class="form-label">Message Content</label>
                            <textarea id="singleMessage" class="form-control" rows="4" placeholder="Type your custom message..." required></textarea>
                        </div>

                        <button type="submit" id="btn-send-single" class="btn btn-primary w-100 py-2">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-dark">Live Preview</h6>
                </div>
                <div class="card-body bg-light d-flex flex-column align-items-center justify-content-center p-4">
                    
                    <div class="bg-white p-3 shadow-sm w-100" style="border-radius: 15px 15px 15px 0 !important; border: 1px solid #e3e6f0;">
                        <p id="livePreviewText" class="mb-0 text-dark" style="white-space: pre-wrap; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.4;">Type a message or select a template to see the preview here...</p>
                    </div>
                    
                    <div class="mt-3 text-muted small w-100 d-flex justify-content-between">
                        <span><strong id="previewSmsCount">0</strong> SMS Part(s)</span>
                        <span><strong id="previewCharCount">0</strong> Characters</span>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/customjs/messages.js"></script>
{% endblock %}