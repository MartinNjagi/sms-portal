{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
        <h2 class="h3 mb-2 mb-sm-0 text-gray-800">{{ title | default('Configuration & Settings') }}</h2>
    </div>

    {% if user.role == 'ADMIN' %}
    <div class="alert alert-dark d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm mb-4">
        <div>
            <strong>🛡️ Admin Override Mode</strong>
            <p class="mb-0 small text-muted">You are currently viewing configuration settings for:</p>
        </div>
        <div class="mt-2 mt-md-0 d-flex gap-2 align-items-center">
            <select id="adminClientSwitcher" class="form-select form-select-sm w-auto">
                <option value="">My Own Config (Admin)</option>
                </select>
            <button id="btn-load-client" class="btn btn-sm btn-dark">Load</button>
        </div>
    </div>
    {% endif %}

    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="list-group list-group-flush" id="settings-list-tab" role="tablist">
                    <a class="list-group-item list-group-item-action active d-flex align-items-center" data-bs-toggle="list" href="#profile" role="tab">
                        <span class="me-2">👤</span> Profile Info
                    </a>
                    <a class="list-group-item list-group-item-action d-flex align-items-center" data-bs-toggle="list" href="#senderids" role="tab">
                        <span class="me-2">🏷️</span> Sender IDs
                    </a>
                    <a class="list-group-item list-group-item-action d-flex align-items-center" data-bs-toggle="list" href="#templates" role="tab">
                        <span class="me-2">📄</span> Message Templates
                    </a>
                    <a class="list-group-item list-group-item-action d-flex align-items-center" data-bs-toggle="list" href="#api" role="tab">
                        <span class="me-2">🔌</span> API & Webhooks
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="tab-content" id="nav-tabContent">
                
                <div class="tab-pane fade show active" id="profile" role="tabpanel">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="mb-3">Profile Information</h4>
                            <p class="text-muted mb-4">Manage your account details, security preferences, and timezone.</p>
                            </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="senderids" role="tabpanel">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
                                <div>
                                    <h4 class="m-0">My Sender IDs</h4>
                                    <p class="text-muted small m-0">Identities your messages are sent from.</p>
                                </div>
                                <button class="btn btn-primary mt-3 mt-sm-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#requestSenderIdModal">
                                    + Request New
                                </button>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mt-2">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Sender ID</th>
                                            <th>Status</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for sender in senderIds %}
                                        <tr id="row-sender-{{ sender.id }}">
                                            <td><strong>{{ sender.sender_id or sender.id }}</strong></td>
                                            <td>
                                                {% if sender.status == 'APPROVED' %}
                                                    <span class="badge bg-success">Approved</span>
                                                {% elif sender.status == 'REJECTED' %}
                                                    <span class="badge bg-danger">Rejected</span>
                                                {% else %}
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-end">
                                                {% if user.role == 'ADMIN' and sender.status != 'APPROVED' %}
                                                    <button class="btn btn-sm btn-success approve-sender-btn" data-id="{{ sender.id }}">Approve</button>
                                                    <button class="btn btn-sm btn-warning reject-sender-btn" data-id="{{ sender.id }}">Reject</button>
                                                {% endif %}
                                                <button class="btn btn-sm btn-outline-danger delete-sender-btn" data-id="{{ sender.id }}">Delete</button>
                                            </td>
                                        </tr>
                                        {% else %}
                                        <tr>
                                            <td colspan="3" class="text-center text-muted py-4">No Sender IDs found. Request one to get started.</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="templates" role="tabpanel">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
                                <div>
                                    <h4 class="m-0">Message Templates</h4>
                                    <p class="text-muted small m-0">Pre-approved content for faster sending.</p>
                                </div>
                                <button class="btn btn-primary mt-3 mt-sm-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#createTemplateModal">
                                    + Create Template
                                </button>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mt-2">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Template Name</th>
                                            <th>Content Preview</th>
                                            <th>Status</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for tpl in templates %}
                                        <tr id="row-template-{{ tpl.id }}">
                                            <td><strong>{{ tpl.name }}</strong></td>
                                            <td class="text-truncate" style="max-width: 250px;" title="{{ tpl.content }}">{{ tpl.content }}</td>
                                            <td>
                                                {% if tpl.status == 'APPROVED' %}
                                                    <span class="badge bg-success">Approved</span>
                                                {% elif tpl.status == 'REJECTED' %}
                                                    <span class="badge bg-danger">Rejected</span>
                                                {% else %}
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-end">
                                                {% if user.role == 'ADMIN' and tpl.status != 'APPROVED' %}
                                                    <button class="btn btn-sm btn-success approve-template-btn" data-id="{{ tpl.id }}">Approve</button>
                                                    <button class="btn btn-sm btn-warning reject-template-btn" data-id="{{ tpl.id }}">Reject</button>
                                                {% endif %}
                                                <button class="btn btn-sm btn-outline-danger delete-template-btn" data-id="{{ tpl.id }}">Delete</button>
                                            </td>
                                        </tr>
                                        {% else %}
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">No Templates found. Create one to save time.</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="api" role="tabpanel">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="mb-4">Developer API & Webhooks</h4>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Live API Key</label>
                                <div class="input-group">
                                    <input type="text" class="form-control bg-light" value="{{ devSettings.apiKey }}" readonly>
                                    <button class="btn btn-outline-secondary" type="button">Copy</button>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">DLR Webhook URL</label>
                                <input type="url" class="form-control" value="{{ devSettings.webhookUrl }}" placeholder="https://your-domain.com/api/dlr">
                                <div class="form-text">The Go Engine will POST Delivery Reports (DLRs) to this URL.</div>
                            </div>
                            <button class="btn btn-success px-4">Save Webhook Settings</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="requestSenderIdModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form id="form-request-sender-id" class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title">Request Sender ID</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Sender ID</label>
                    <input type="text" id="senderIdInput" class="form-control" maxlength="11" placeholder="Max 11 Characters" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Justification / Use Case</label>
                    <textarea id="senderIdJustification" class="form-control" rows="3" required placeholder="Explain what type of messages you will send to assist compliance approval..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btn-submit-sender">Submit Request</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="createTemplateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form id="form-create-template" class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title">Create Message Template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Template Name</label>
                    <input type="text" id="templateNameInput" class="form-control" required placeholder="e.g., OTP Verification">
                </div>
                <div class="mb-3">
                    <label class="form-label">Message Content</label>
                    <textarea id="templateContentInput" class="form-control" rows="4" required placeholder="Your RahaPay code is [CODE]..."></textarea>
                    <div class="form-text">Variables like [CODE] or [NAME] can be injected during sending.</div>
                </div>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btn-submit-template">Create Template</button>
            </div>
        </form>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/customjs/settings.js"></script>
{% endblock %}