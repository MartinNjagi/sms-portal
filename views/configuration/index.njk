{% extends "layout-v2.njk" %}

{% block content %}
<div class="page-header">
    <h1>{{ title }}</h1>
</div>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="list-group" id="settings-list-tab" role="tablist">
            <a class="list-group-item list-group-item-action active" data-toggle="list" href="#profile" role="tab">Profile Info</a>
            <a class="list-group-item list-group-item-action" data-toggle="list" href="#senderids" role="tab">Sender IDs</a>
            <a class="list-group-item list-group-item-action" data-toggle="list" href="#templates" role="tab">Message Templates</a>
            <a class="list-group-item list-group-item-action" data-toggle="list" href="#api" role="tab">API & Webhooks</a>
        </div>
    </div>

    <div class="col-md-9">
        <div class="tab-content" id="nav-tabContent">
            
            <div class="tab-pane fade show active" id="profile" role="tabpanel">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h3>Profile Information</h3>
                        <p class="text-muted">Manage your account details and preferences.</p>
                        </div>
                </div>
            </div>

            <div class="tab-pane fade" id="senderids" role="tabpanel">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="m-0">My Sender IDs</h3>
                            <button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#requestSenderIdModal">Request New</button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mt-3">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Sender ID</th>
                                        <th>Status</th>
                                        <th class="text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for sender in senderIds %}
                                    <tr id="row-sender-{{ sender.id }}">
                                        <td><strong>{{ sender.name or sender.id }}</strong></td>
                                        <td>
                                            {% if sender.status == 'approved' %}
                                                <span class="badge badge-success">Approved</span>
                                            {% elif sender.status == 'rejected' %}
                                                <span class="badge badge-danger">Rejected</span>
                                            {% else %}
                                                <span class="badge badge-warning">Pending</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-right">
                                            <button class="btn btn-sm btn-outline-danger delete-sender-btn" data-id="{{ sender.id }}">Delete</button>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center text-muted">No Sender IDs found. Request one to get started.</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="templates" role="tabpanel">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="m-0">Message Templates</h3>
                            <button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#createTemplateModal">Create Template</button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mt-3">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Template Name</th>
                                        <th>Content Preview</th>
                                        <th>Status</th>
                                        <th class="text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for tpl in templates %}
                                    <tr id="row-template-{{ tpl.id }}">
                                        <td><strong>{{ tpl.name }}</strong></td>
                                        <td class="text-truncate" style="max-width: 200px;" title="{{ tpl.content }}">{{ tpl.content }}</td>
                                        <td>
                                            {% if tpl.status == 'approved' %}
                                                <span class="badge badge-success">Approved</span>
                                            {% elif tpl.status == 'rejected' %}
                                                <span class="badge badge-danger">Rejected</span>
                                            {% else %}
                                                <span class="badge badge-warning">Pending</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-right">
                                            <button class="btn btn-sm btn-outline-danger delete-template-btn" data-id="{{ tpl.id }}">Delete</button>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">No Templates found. Create one to save time.</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="api" role="tabpanel">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h3>Developer API</h3>
                        <div class="form-group mt-3">
                            <label>Live API Key</label>
                            <input type="text" class="form-control" value="{{ devSettings.apiKey }}" readonly>
                        </div>
                        <div class="form-group mt-3">
                            <label>DLR Webhook URL</label>
                            <input type="url" class="form-control" value="{{ devSettings.webhookUrl }}" placeholder="https://your-domain.com/dlr">
                            <small class="text-muted">The Go Engine will POST delivery reports to this URL.</small>
                        </div>
                        <button class="btn btn-success">Save Webhook</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="requestSenderIdModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <form id="form-request-sender-id" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Sender ID</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Sender ID (max 11 chars)</label>
                    <input type="text" id="senderIdInput" class="form-control" maxlength="11" required>
                </div>
                <div class="form-group">
                    <label>Justification / Use Case</label>
                    <textarea id="senderIdJustification" class="form-control" rows="3" required placeholder="Explain what type of messages you will send..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btn-submit-sender">Submit Request</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="createTemplateModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <form id="form-create-template" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Template</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Template Name</label>
                    <input type="text" id="templateNameInput" class="form-control" required placeholder="e.g., OTP Verification">
                </div>
                <div class="form-group">
                    <label>Message Content</label>
                    <textarea id="templateContentInput" class="form-control" rows="4" required placeholder="Your code is [CODE]..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btn-submit-template">Create Template</button>
            </div>
        </form>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/customjs/settings.js"></script>
{% endblock %}