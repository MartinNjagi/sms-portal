{% extends "../layout-v2.njk" %}

{% block content %}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>{{ title }}</h1>
        <p class="text-muted mb-0">Manage platform tenants, review ledgers, and control access.</p>
    </div>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#createClientModal">
        + Register New Tenant
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Company Name</th>
                        <th>Status</th>
                        <th>Credit Balance</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for client in clients %}
                    <tr>
                        <td class="ps-4 fw-bold">
                            {{ client.name }}
                            {% if client.id == 1 %} <span class="badge bg-dark ms-2">System Admin</span> {% endif %}
                        </td>
                        <td>
                            {% if client.status == 'active' %}
                                <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle">Active</span>
                            {% elif client.status == 'suspended' %}
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle">Suspended</span>
                            {% else %}
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle">{{ client.status | capitalize }}</span>
                            {% endif %}
                        </td>
                        <td class="font-monospace text-primary fw-bold">
                            {{ client.balance | default(0) | intcomma }}
                        </td>
                        <td class="text-end pe-4">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light border" type="button" data-bs-toggle="dropdown">
                                    Options <i class="bi bi-chevron-down ms-1"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                    <li><button class="dropdown-item text-primary btn-edit-client" data-id="{{ client.id }}" data-name="{{ client.name }}"><i class="bi bi-pencil-square me-2"></i> Edit Company</button></li>
                                    <li><a class="dropdown-item" href="/clients/{{ client.id }}/wallet"><i class="bi bi-wallet2 me-2 text-muted"></i> View Ledger</a></li>
                                    <li><a class="dropdown-item" href="/clients/{{ client.id }}/users"><i class="bi bi-people me-2 text-muted"></i> View Users</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    
                                    {% if client.status == 'active' %}
                                        <li><button class="dropdown-item text-danger btn-suspend" data-id="{{ client.id }}" data-name="{{ client.name }}"><i class="bi bi-pause-circle me-2"></i> Suspend Account</button></li>
                                    {% elif client.status == 'suspended' %}
                                        <li><button class="dropdown-item text-success btn-reinstate" data-id="{{ client.id }}" data-name="{{ client.name }}"><i class="bi bi-play-circle me-2"></i> Reinstate Account</button></li>
                                    {% endif %}
                                </ul>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if pendingTransfers.length > 0 %}
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow border-left-warning">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 font-weight-bold text-warning">
                    <i class="bi bi-bank"></i> Action Required: Pending Bank Receipts
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-3">Date</th>
                                <th>Client ID</th>
                                <th>Amount Deposited</th>
                                <th>Expected SMS</th>
                                <th>Bank Reference</th>
                                <th class="text-center px-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for txn in pendingTransfers %}
                            <tr id="txn-row-{{ txn.ID }}">
                                <td class="px-3">{{ txn.CreatedAt | date("YYYY-MM-DD HH:mm") }}</td>
                                <td><span class="badge bg-secondary">Client #{{ txn.ClientID }}</span></td>
                                <td class="font-weight-bold">{{ txn.Amount | intcomma }} KES</td>
                                <td class="text-success fw-bold">+{{ txn.Credits | intcomma }} SMS</td>
                                <td><code class="text-dark">{{ txn.ReferenceNumber }}</code></td>
                                <td class="text-center px-3">
                                    <button class="btn btn-sm btn-success btn-process-txn" data-id="{{ txn.ID }}" data-action="APPROVED">Approve</button>
                                    <button class="btn btn-sm btn-outline-danger btn-process-txn" data-id="{{ txn.ID }}" data-action="REJECTED">Reject</button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<div class="modal fade" id="createClientModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form id="form-create-client" class="modal-content border-0 shadow" autocomplete="off">
            <div class="modal-header border-bottom-0 bg-light">
                <h5 class="modal-title">Register New Tenant</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Company / Tenant Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="newClientName" required placeholder="e.g. Acme Corp">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Initial Status</label>
                    <select class="form-select" id="newClientStatus">
                        <option value="active" selected>Active</option>
                        <option value="pending">Pending</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btn-submit-create">Register Tenant</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="editClientModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form id="form-edit-client" class="modal-content border-0 shadow" autocomplete="off">
            <div class="modal-header border-bottom-0 bg-light">
                <h5 class="modal-title">Edit Tenant</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="editClientId">
                <div class="mb-3">
                    <label class="form-label fw-bold">Company / Tenant Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="editClientName" required>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btn-submit-edit">Save Changes</button>
            </div>
        </form>
    </div>
</div>


{% endblock %}

{% block scripts %}
<script src="/js/customjs/clients.js"></script>
{% endblock %}