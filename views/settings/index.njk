{% extends "../layout-v2.njk" %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
        <h2 class="h3 mb-2 mb-sm-0 text-gray-800">{{ title | default('Account & Billing Settings') }}</h2>
    </div>

    {% if user.role == 'ADMIN' %}
    <div class="alert alert-dark d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm mb-4">
        <div>
            <strong>🛡️ Admin Override Mode</strong>
            <p class="mb-0 small text-muted">You are currently viewing configuration settings for:</p>
        </div>
        <div class="mt-2 mt-md-0 d-flex gap-2 align-items-center">
            <select id="adminClientSwitcher" class="form-select form-select-sm w-auto">
                <option value="">My Own Config (Admin)</option>
                {% for c in clients %}
                    <option value="{{ c.id }}" {% if targetClientId == c.id %}selected{% endif %}>[{{ c.id }}] {{ c.name }}</option>
                {% endfor %}
            </select>
            <button id="btn-load-client" class="btn btn-sm btn-light">Load</button>
        </div>
    </div>
    {% endif %}

    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="list-group list-group-flush" id="settings-list-tab" role="tablist">
                    <a class="list-group-item list-group-item-action active d-flex align-items-center" data-bs-toggle="list" href="#profile" role="tab">
                        <span class="me-2">👤</span> Profile Info
                    </a>
                    <a class="list-group-item list-group-item-action d-flex align-items-center" data-bs-toggle="list" href="#api" role="tab">
                        <span class="me-2">🔌</span> API Keys & Webhooks
                    </a>
                    <a class="list-group-item list-group-item-action d-flex align-items-center" data-bs-toggle="list" href="#passkeys" role="tab">
                        <span class="me-2">🔑</span> Passkeys
                    </a>
                    {% if user.role == 'ADMIN' %}
                    <a class="list-group-item list-group-item-action d-flex align-items-center bg-dark text-white mt-3" data-bs-toggle="list" href="#adminBilling" role="tab" style="border-radius: 0 0 5px 5px;">
                        <span class="me-2">🛡️</span> Admin Billing Controls
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="tab-content" id="nav-tabContent">
                
                <div class="tab-pane fade show active" id="profile" role="tabpanel">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="mb-3">Profile Information</h4>
                            <p class="text-muted mb-4">Manage your account details and security preferences.</p>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase">Account Name</label>
                                    <input type="text" class="form-control bg-light" value="{{ user.name }}" readonly>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase">Email Address</label>
                                    <input type="email" class="form-control bg-light" value="{{ user.email }}" readonly>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="api" role="tabpanel">
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4 bg-light rounded border">
                            <h6 class="text-uppercase text-muted small fw-bold mb-2">Your API Account ID</h6>
                            <p class="small text-muted mb-2">Include this ID in your API requests to identify your account.</p>
                            <div class="input-group">
                                <input type="text" id="apiAccountId" class="form-control font-monospace text-primary fw-bold bg-white" value="{{ user.public_id }}" readonly>
                                <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('apiAccountId').value); alert('Account ID Copied!');">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <h4 class="m-0">API Keys</h4>
                                    <p class="text-muted small m-0">Manage access keys for the REST API.</p>
                                </div>
                                <button class="btn btn-sm btn-primary" id="btn-generate-key">+ Generate New Key</button>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Key Prefix</th>
                                            <th>Created</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for key in apiKeys %}
                                        <tr id="row-key-{{ key.id }}">
                                            <td><code class="text-dark">{{ key.prefix }}****************</code></td>
                                            <td>{{ key.created_at | truncate(10, true, "") }}</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger btn-revoke-key" data-id="{{ key.id }}">Revoke</button>
                                            </td>
                                        </tr>
                                        {% else %}
                                        <tr>
                                            <td colspan="3" class="text-center text-muted py-4">No API keys generated yet.</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="mb-3">DLR Webhook</h4>
                            <p class="text-muted small mb-4">The Go Engine will POST Delivery Reports (DLRs) to this URL.</p>
                            
                            <form id="form-webhook" autocomplete="off">
                                <div class="mb-3">
                                    <input type="url" class="form-control" id="webhookUrl" value="{{ billingConfig.webhook_url }}" placeholder="https://your-domain.com/api/dlr">
                                </div>
                                <button type="submit" class="btn btn-success px-4">Save Webhook</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="passkeys" role="tabpanel">
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <h4 class="m-0">Passkeys</h4>
                                    <p class="text-muted small m-0">Sign in securely using your device's fingerprint, face scan, or screen lock.</p>
                                </div>
                                <button class="btn btn-sm btn-primary" id="btn-register-passkey">+ Register Device</button>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Device / Credential Name</th>
                                            <th>Created</th>
                                            <th>Last Used</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for passkey in passkeys %}
                                        <tr id="row-passkey-{{ passkey.id }}">
                                            <td>
                                                <strong><i class="fas fa-fingerprint text-primary me-2"></i> {{ passkey.name | default('Registered Device') }}</strong>
                                            </td>
                                            <td>{{ passkey.created_at | truncate(10, true, "") }}</td>
                                            <td>{{ passkey.last_used_at | default('Never') | truncate(10, true, "") }}</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger btn-delete-passkey" data-id="{{ passkey.id }}">Remove</button>
                                            </td>
                                        </tr>
                                        {% else %}
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">No passkeys registered to this account.</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                {% if user.role == 'ADMIN' %}
                <div class="tab-pane fade" id="adminBilling" role="tabpanel">
                    
                    <div class="card shadow-sm border-0 border-left-primary mb-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="m-0 font-weight-bold text-dark">Manual Wallet Adjustment</h5>
                            <p class="text-muted small m-0">Credit or debit a client's account directly.</p>
                        </div>
                        <div class="card-body p-4">
                            <form id="form-manual-adjustment" autocomplete="off">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="fw-bold">Target Client <span class="text-danger">*</span></label>
                                        <select id="adjClientId" class="form-select admin-client-dropdown" required>
                                            <option value="" disabled selected>Select a client...</option>
                                            {% for c in clients %}
                                                <option value="{{ c.id }}">[{{ c.id }}] {{ c.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="fw-bold">Action <span class="text-danger">*</span></label>
                                        <select id="adjAction" class="form-select" required>
                                            <option value="CREDIT">Credit (Add Funds)</option>
                                            <option value="DEBIT">Debit (Deduct Funds)</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="fw-bold">Amount (Credits/KES) <span class="text-danger">*</span></label>
                                        <input type="number" id="adjCredits" class="form-control" min="1" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="fw-bold">Description / Reason <span class="text-danger">*</span></label>
                                        <input type="text" id="adjDescription" class="form-control" placeholder="e.g., Promotional Bonus, SLA Refund" required>
                                    </div>
                                </div>
                                <button type="submit" id="btn-submit-adj" class="btn btn-primary mt-2">Apply Adjustment</button>
                            </form>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 border-left-warning">
                        <div class="card-header bg-white py-3">
                            <h5 class="m-0 font-weight-bold text-dark">Update Client Billing Configuration</h5>
                            <p class="text-muted small m-0">Override base rates or SLA refund settings for specific tenants.</p>
                        </div>
                        <div class="card-body p-4">
                            <form id="form-billing-config" autocomplete="off">
                                <div class="row">
                                    <div class="col-md-12 mb-3">
                                        <label class="fw-bold">Target Client <span class="text-danger">*</span></label>
                                        <select id="cfgClientId" class="form-select admin-client-dropdown" required>
                                            <option value="" disabled selected>Select a client...</option>
                                            {% for c in clients %}
                                                <option value="{{ c.id }}">[{{ c.id }}] {{ c.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="fw-bold">Base SMS Rate (KES)</label>
                                        <input type="number" id="cfgBaseRate" class="form-control" step="0.01" min="0" placeholder="e.g., 0.80">
                                        <small class="text-muted">Leave blank to keep existing rate.</small>
                                    </div>
                                    <div class="col-md-6 mb-3 d-flex align-items-center mt-3 mt-md-0">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="cfgRefund" value="true">
                                            <label class="form-check-label fw-bold" for="cfgRefund">
                                                Refund on Failed Delivery?
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <button type="submit" id="btn-submit-cfg" class="btn btn-warning text-dark mt-2">Update Configuration</button>
                            </form>
                        </div>
                    </div>

                </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="apiKeyModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title text-success"><i class="fas fa-check-circle"></i> API Key Generated</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-danger fw-bold">Please copy this key immediately. It will not be shown again.</p>
                <div class="input-group mb-3">
                    <input type="text" id="newApiKeyValue" class="form-control text-center font-monospace fs-5" readonly>
                    <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('newApiKeyValue').value); alert('Copied!');">Copy</button>
                </div>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-primary w-100" data-bs-dismiss="modal" onclick="location.reload()">I have copied it securely</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/customjs/settings.js"></script>
{% endblock %}